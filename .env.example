
# 项目基础设置
ENV=development
LOG_LEVEL=DEBUG
APP_CONFIG_FILEPATH=config.yaml

# 数据库相关的配置
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@manus-postgres:5432/manus

# Redis相关配置
REDIS_HOST=manus-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 腾讯云cos相关配置
COS_SECRET_ID=<your-cos-secret-id>
COS_SECRET_KEY=<your-cos-secret-key>
COS_REGION=ap-guangzhou
COS_SCHEME=https
COS_BUCKET=<your-cos-bucket>
COS_DOMAIN=

# 沙箱配置
SANDBOX_ADDRESS=manus-sandbox
SANDBOX_IMAGE=manus-sandbox
SANDBOX_NAME_PREFIX=mooc-manus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=manus-network
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=
